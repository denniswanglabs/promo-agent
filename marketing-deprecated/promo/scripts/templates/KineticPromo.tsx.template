};

const FeatureMontageScene: React.FC<SceneRendererProps> = ({ scene }) => {
  const frame = useCurrentFrame();
  const items = scene.copy;
  const STAGGER = 8;
  const ITEM_DUR = 22;
  const START = 4;

  return (
    <AbsoluteFill
      style={{
        alignItems: "center",
        justifyContent: "center",
        flexDirection: "column",
        gap: 24,
        padding: "0 100px",
      }}
    >
      {items.map((line: string, i: number) => {
        const l = frame - START - i * STAGGER;
        const p = interpolate(l, [0, ITEM_DUR], [0, 1], {
          extrapolateLeft: "clamp",
          extrapolateRight: "clamp",
          easing: Easing.bezier(0.22, 1, 0.36, 1),
        });
        const isLast = i === items.length - 1;
        return (
          <div
            key={i}
            style={{
              display: "flex",
              alignItems: "center",
              gap: 28,
              opacity: p,
              transform: `translateY(${(1 - p) * 36}px)`,
            }}
          >
            <div
              style={{
                width: 14,
                height: 14,
                borderRadius: 7,
                background: isLast ? themeColors.accent : themeColors.text,
                opacity: 0.85,
              }}
            />
            <div
              style={{
                fontFamily: FONT_STACK,
                fontSize: 64,
                fontWeight: 600,
                letterSpacing: "-0.02em",
                color: isLast ? themeColors.accent : themeColors.text,
                lineHeight: 1.1,
              }}
            >
              {line}
            </div>
          </div>
        );
      })}
    </AbsoluteFill>
  );
};

