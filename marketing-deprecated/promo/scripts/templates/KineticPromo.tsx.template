    durationInFrames: 26,
    config: { damping: 200, mass: 0.5 },
  });
  const quoteY = interpolate(quoteIn, [0, 1], [40, 0]);
  const breath = frame > 32 ? Math.sin((frame - 32) / 60) * 1.2 : 0;

  const attrOpacity = interpolate(frame, [28, 44], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const quote = scene.copy[0] ?? "";
  const attribution = scene.copy[1];

  return (
    <AbsoluteFill
      style={{
        alignItems: "center",
        justifyContent: "center",
        flexDirection: "column",
        gap: 36,
        padding: "0 140px",
      }}
    >
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 140,
          fontWeight: 700,
          color: themeColors.accent,
          lineHeight: 0.6,
          marginBottom: -30,
          opacity: quoteIn * 0.6,
        }}
      >
        “
      </div>
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 56,
          fontWeight: 500,
          fontStyle: "italic",
          letterSpacing: "-0.02em",
          color: themeColors.text,
          opacity: quoteIn,
          transform: `translateY(${quoteY + breath}px)`,
          lineHeight: 1.25,
          textAlign: "center",
          maxWidth: 1400,
        }}
      >
        {quote}
      </div>
      {attribution ? (
