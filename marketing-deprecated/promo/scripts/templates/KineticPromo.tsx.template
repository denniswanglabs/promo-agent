};

const CtaScene: React.FC<SceneRendererProps> = ({ scene }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();

  const titleSpring = spring({
    frame: frame - 4,
    fps,
    config: { damping: 14, stiffness: 150 },
  });
  const titleScale = interpolate(titleSpring, [0, 1], [0.85, 1]);
  const titleOpacity = interpolate(frame, [4, 20], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const accentScale = interpolate(frame, [14, 30], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
    easing: Easing.bezier(0.22, 1, 0.36, 1),
  });

  const subOpacity = interpolate(frame, [22, 40], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const pulse = 1 + Math.sin(frame / 8) * 0.04;
  const pulseGlow = 0.5 + Math.sin(frame / 8) * 0.5;

  const primary = scene.copy[0] ?? "";
  const sub = scene.copy[1];

  return (
    <AbsoluteFill
      style={{
        alignItems: "center",
        justifyContent: "center",
        flexDirection: "column",
        gap: 30,
      }}
    >
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 112,
          fontWeight: 700,
          letterSpacing: "-0.035em",
          color: themeColors.text,
          opacity: titleOpacity,
          transform: `scale(${titleScale})`,
          lineHeight: 1,
          textAlign: "center",
        }}
      >
        {primary}
      </div>
      <div
        style={{
          width: 280,
          height: 4,
          background: themeColors.accent,
          borderRadius: 2,
          transform: `scaleX(${accentScale})`,
          boxShadow: `0 0 ${20 * pulseGlow}px ${themeColors.accent}`,
        }}
      />
      {sub ? (
        <div
          style={{
            fontFamily: MONO_STACK,
            fontSize: 28,
            fontWeight: 600,
            letterSpacing: "0.18em",
            color: themeColors.accent,
            opacity: subOpacity,
            padding: "14px 36px",
            border: `2px solid ${themeColors.accent}`,
            borderRadius: 999,
            transform: `scale(${pulse})`,
            textTransform: "uppercase",
          }}
        >
          {sub}
        </div>
      ) : null}
    </AbsoluteFill>
  );
};

// Act/scene marker — small upper-left label per scene
const SceneMarker: React.FC<{ scene: typeof SPEC.scenes[number]; sceneDuration: number }> = ({
  scene,
  sceneDuration,
}) => {
  const frame = useCurrentFrame();
  const opacity = interpolate(
    frame,
    [4, 14, sceneDuration - 8, sceneDuration - 1],
    [0, 1, 1, 0],
    { extrapolateLeft: "clamp", extrapolateRight: "clamp" }
  );
  return (
    <AbsoluteFill style={{ pointerEvents: "none", padding: "60px 80px" }}>
      <div
        style={{
          fontFamily: MONO_STACK,
          fontSize: 16,
          fontWeight: 600,
          letterSpacing: "0.32em",
          textTransform: "uppercase",
          color: themeColors.textMuted,
          opacity,
        }}
      >
        {String(scene.act).padStart(2, "0")} · {scene.type.replace(/_/g, " ")}
      </div>
    </AbsoluteFill>
  );
};

const SCENE_RENDERERS: Record<string, React.FC<SceneRendererProps>> = {
  cold_open: ColdOpenScene,
  problem: ProblemScene,
  solution_reveal: SolutionRevealScene,
  feature_montage: FeatureMontageScene,
  social_proof: SocialProofScene,
  cta: CtaScene,
};

// ---- Top-level composition -----------------------------------------------

export const KineticPromo: React.FC = () => {
  const frame = useCurrentFrame();

  let cursor = 0;
  const sceneRanges = SPEC.scenes.map((scene: typeof SPEC.scenes[number]) => {
    const start = cursor;
    const duration = scene.duration_f;
    cursor += duration;
    return { scene, start, duration };
  });

  const musicTrack = (SPEC as any).music?.track ?? "corporate";

  return (
    <AbsoluteFill style={{ fontFamily: FONT_STACK }}>
      <Audio
        src={staticFile(`audio/${musicTrack}.mp3`)}
        volume={(f) =>
          interpolate(
            f,
            [
              0,
              30,
              SPEC.total_duration_f - 45,
              SPEC.total_duration_f,
            ],
            [0, 0.85, 0.85, 0],
            { extrapolateLeft: "clamp", extrapolateRight: "clamp" }
          )
        }
      />

      <AuroraBg />

      {sceneRanges.map(({ scene, start, duration }, idx: number) => {
        const Renderer = SCENE_RENDERERS[scene.type] ?? ColdOpenScene;
        return (
          <Sequence key={idx} from={start} durationInFrames={duration}>
            <Renderer scene={scene} />
            <SceneMarker scene={scene} sceneDuration={duration} />
          </Sequence>
        );
      })}

      {/* Visual fade to black: 30f ending 15f before composition end (audio outlasts) */}
      <AbsoluteFill
        style={{
          background: "#000000",
          opacity: interpolate(
            frame,
            [SPEC.total_duration_f - 45, SPEC.total_duration_f - 15],
            [0, 1],
            { extrapolateLeft: "clamp", extrapolateRight: "clamp" }
          ),
          pointerEvents: "none",
        }}
      />
    </AbsoluteFill>
  );
};
