// KineticPromo — pure kinetic-typography promo, no image/video assets needed.
// Motion adapted from:
//   ~/Desktop/Projects/Demos/alai-promo/src/scenes/ColdOpen.tsx (word stagger)
//   ~/Desktop/Projects/Demos/alai-promo/src/scenes/Reveal.tsx (settle spring + breath drift)
//   ~/Desktop/Projects/Orinovate/orinovate-video/src/scenes/IntroScene.tsx (wordmark entry)
//
// Important Remotion semantics used here:
//   - Inside a <Sequence>, useCurrentFrame() returns SEQUENCE-LOCAL frames (0..duration_f).
//   - Each scene component just uses `frame` directly — no absolute-time math needed.

import React from "react";
import {
  AbsoluteFill,
  Audio,
  Sequence,
  interpolate,
  spring,
  staticFile,
  useCurrentFrame,
  useVideoConfig,
  Easing,
} from "remotion";

const SPEC = __SPEC_JSON__ as const;

// ---- Theme derivation ----------------------------------------------------

function hexToRgb(hex: string): [number, number, number] {
  const h = hex.replace("#", "");
  return [
    parseInt(h.substring(0, 2), 16) / 255,
    parseInt(h.substring(2, 4), 16) / 255,
    parseInt(h.substring(4, 6), 16) / 255,
  ];
}

function luminance(hex: string): number {
  const [r, g, b] = hexToRgb(hex);
  const lin = (c: number) =>
    c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
  return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
}

function shade(hex: string, amount: number): string {
  const [r, g, b] = hexToRgb(hex);
  const adj = (c: number) =>
    amount >= 0 ? c + (1 - c) * amount : c * (1 + amount);
  const to = (c: number) =>
    Math.round(Math.max(0, Math.min(1, c)) * 255)
      .toString(16)
      .padStart(2, "0");
  return "#" + to(adj(r)) + to(adj(g)) + to(adj(b));
}

const isDark = luminance(SPEC.palette.primary) < 0.45;

const themeColors = isDark
  ? {
      bg: SPEC.palette.primary,
      text: "#ffffff",
      textDim: "rgba(255,255,255,0.7)",
      textMuted: "rgba(255,255,255,0.45)",
      accent: SPEC.palette.accent,
      noiseOpacity: 0.04,
      mixBlend: "screen" as const,
    }
  : {
      bg: "#ffffff",
      text: "#0a0a0a",
      textDim: "rgba(10,10,10,0.65)",
      textMuted: "rgba(10,10,10,0.4)",
      accent: SPEC.palette.primary,
      noiseOpacity: 0.025,
      mixBlend: "multiply" as const,
    };

const FONT_STACK =
  "'Inter', 'Albert Sans', 'Geist', 'Noto Sans TC', system-ui, -apple-system, sans-serif";
const MONO_STACK =
  "'Geist Mono', 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace";

// ---- Background — aurora gradient + noise (rendered at parent level) -----

const AuroraBg: React.FC = () => {
  const frame = useCurrentFrame();
  const drift = Math.sin(frame / 80) * 8;
  return (
    <AbsoluteFill style={{ backgroundColor: themeColors.bg }}>
      <AbsoluteFill
        style={{
          opacity: 0.55,
          background: isDark
            ? `
                radial-gradient(ellipse 1100px 700px at ${18 + drift}% 95%, ${themeColors.accent}55 0%, transparent 60%),
                radial-gradient(ellipse 1000px 680px at ${82 - drift}% 5%, ${shade(themeColors.accent, -0.2)}66 0%, transparent 60%),
                radial-gradient(ellipse 900px 600px at 50% 50%, ${themeColors.accent}22 0%, transparent 70%)
              `
            : `
                radial-gradient(ellipse 1200px 800px at ${18 + drift}% 95%, ${SPEC.palette.primary}22 0%, transparent 60%),
                radial-gradient(ellipse 1000px 700px at ${82 - drift}% 5%, ${SPEC.palette.accent}33 0%, transparent 60%)
              `,
        }}
      />
      <AbsoluteFill
        style={{
          opacity: themeColors.noiseOpacity,
          background: `url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence baseFrequency='0.9' numOctaves='2' seed='5'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>") repeat`,
          mixBlendMode: themeColors.mixBlend,
        }}
      />
    </AbsoluteFill>
  );
};

// ---- Scene components (frame is sequence-local) --------------------------

interface SceneRendererProps {
  scene: typeof SPEC.scenes[number];
}

const ColdOpenScene: React.FC<SceneRendererProps> = ({ scene }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();

  const titleSpring = spring({
    frame: frame - 6,
    fps,
    config: { damping: 16, stiffness: 170 },
  });
  const titleY = interpolate(titleSpring, [0, 1], [40, 0]);
  const titleScale = interpolate(titleSpring, [0, 1], [1.08, 1]);
  const titleOpacity = interpolate(frame, [6, 22], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const breath = frame > 30 ? Math.sin((frame - 30) / 14) * 1.2 : 0;

  const underline = interpolate(frame, [18, 38], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });
  const subOpacity = interpolate(frame, [30, 50], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const primary = scene.copy[0] ?? "";
  const sub = scene.copy[1];

  return (
    <AbsoluteFill
      style={{
        alignItems: "center",
        justifyContent: "center",
        flexDirection: "column",
        gap: 24,
        transform: `translateY(${breath}px)`,
      }}
    >
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 128,
          fontWeight: 700,
          letterSpacing: "-0.035em",
          color: themeColors.text,
          opacity: titleOpacity,
          transform: `translateY(${titleY}px) scale(${titleScale})`,
          lineHeight: 1,
          textAlign: "center",
          padding: "0 80px",
        }}
      >
        {primary}
      </div>
      <div
        style={{
          width: 320,
          height: 2,
          background: `linear-gradient(90deg, transparent 0%, ${themeColors.accent} 50%, transparent 100%)`,
          transform: `scaleX(${underline})`,
          transformOrigin: "center",
        }}
      />
      {sub ? (
        <div
          style={{
            fontFamily: MONO_STACK,
            fontSize: 22,
            fontWeight: 500,
            letterSpacing: "0.32em",
            textTransform: "uppercase",
            color: themeColors.textDim,
            opacity: subOpacity,
          }}
        >
          {sub}
        </div>
      ) : null}
    </AbsoluteFill>
  );
};

const ProblemScene: React.FC<SceneRendererProps> = ({ scene }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();

  const titleIn = spring({
    frame: frame - 4,
    fps,
    config: { damping: 18, stiffness: 140 },
  });
  const titleY = interpolate(titleIn, [0, 1], [20, 0]);
  const titleOpacity = interpolate(frame, [4, 18], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const subY = interpolate(
    spring({ frame: frame - 24, fps, config: { damping: 18, stiffness: 140 } }),
    [0, 1],
    [20, 0]
  );
  const subOpacity = interpolate(frame, [24, 38], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const glow = Math.sin(frame / 12) * 0.5 + 0.5;
  const glowAlpha = Math.round((0.2 + glow * 0.4) * 255)
    .toString(16)
    .padStart(2, "0");

  const primary = scene.copy[0] ?? "";
  const sub = scene.copy[1];

  return (
    <AbsoluteFill
      style={{
        alignItems: "center",
        justifyContent: "center",
        flexDirection: "column",
        gap: 32,
        padding: "0 100px",
      }}
    >
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 92,
          fontWeight: 800,
          letterSpacing: "-0.03em",
          color: themeColors.text,
          opacity: titleOpacity,
          transform: `translateY(${titleY}px)`,
          lineHeight: 1.05,
          textAlign: "center",
          textShadow: `0 0 ${30 + glow * 40}px ${themeColors.accent}${glowAlpha}`,
        }}
      >
        {primary}
      </div>
      {sub ? (
        <div
          style={{
            fontFamily: FONT_STACK,
            fontSize: 36,
            fontWeight: 500,
            letterSpacing: "-0.005em",
            color: themeColors.textDim,
            opacity: subOpacity,
            transform: `translateY(${subY}px)`,
            textAlign: "center",
          }}
        >
          {sub}
        </div>
      ) : null}
    </AbsoluteFill>
  );
};

const SolutionRevealScene: React.FC<SceneRendererProps> = ({ scene }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();

  const wipe = spring({
    frame: frame - 6,
    fps,
    config: { damping: 22, stiffness: 110 },
  });
  const clipR = interpolate(wipe, [0, 1], [100, 0]);
  const titleX = interpolate(wipe, [0, 1], [-60, 0]);

  const subSpring = spring({
    frame: frame - 24,
    fps,
    config: { damping: 22, stiffness: 110 },
  });
  const subX = interpolate(subSpring, [0, 1], [-50, 0]);
  const subOpacity = interpolate(frame, [24, 40], [0, 1], {
    extrapolateLeft: "clamp",
    extrapolateRight: "clamp",
  });

  const primary = scene.copy[0] ?? "";
  const sub = scene.copy[1];

  return (
    <AbsoluteFill
      style={{
        alignItems: "flex-start",
        justifyContent: "center",
        flexDirection: "column",
        gap: 28,
        padding: "0 120px",
      }}
    >
      <div
        style={{
          width: interpolate(wipe, [0, 1], [0, 80]),
          height: 6,
          background: themeColors.accent,
          borderRadius: 3,
          marginBottom: 12,
        }}
      />
      <div
        style={{
          fontFamily: FONT_STACK,
          fontSize: 108,
          fontWeight: 700,
          letterSpacing: "-0.04em",
          color: themeColors.text,
          lineHeight: 0.98,
          clipPath: `inset(0 ${clipR}% 0 0)`,
          transform: `translateX(${titleX}px)`,
        }}
      >
        {primary}
      </div>
      {sub ? (
        <div
          style={{
            fontFamily: FONT_STACK,
            fontSize: 34,
            fontWeight: 500,
            letterSpacing: "-0.005em",
            color: themeColors.textDim,
            opacity: subOpacity,
            transform: `translateX(${subX}px)`,
